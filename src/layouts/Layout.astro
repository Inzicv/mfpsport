---
// Layout de base — gère SEO (title/meta), Open Graph et le schema.org HealthClub
// commun à toutes les pages. Voir docs/etude-refonte.md §D.1 et §H.6.
import '@fontsource-variable/sora';
import '@fontsource-variable/inter';
import '../styles/global.css';
import { getEntry } from 'astro:content';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import logo from '../assets/logo-mfp-sport.png';
import { localServiceAreas } from '../data/local-seo';

interface Props {
  title: string;
  description: string;
  /** true sur toutes les pages de la préprod : injecte un <meta name="robots" content="noindex"> */
  noindex?: boolean;
}

// La préprod entière est en noindex (build avec PREPROD=true — voir
// .github/workflows/deploy-preprod.yml), qu'une page le précise ou non.
const { title, description, noindex = process.env.PREPROD === 'true' } = Astro.props;

const infos = await getEntry('infos', 'infos-pratiques');

const canonical = new URL(Astro.url.pathname, Astro.site).toString();
const businessUrl = new URL('/', Astro.site).toString();

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'HealthClub',
  '@id': `${businessUrl}#mfp-sport`,
  name: 'MFP Sport',
  description:
    'Salle de sport et centre de coaching sportif à Arles : entraînement, préparation physique, nutrition, récupération et préparation mentale.',
  url: businessUrl,
  logo: new URL(logo.src, Astro.site).toString(),
  ...(infos?.data.telephone ? { telephone: infos.data.telephone } : {}),
  email: infos?.data.email,
  address: {
    '@type': 'PostalAddress',
    streetAddress: '15 Chemin des Moines',
    addressLocality: 'Arles',
    addressRegion: 'Provence-Alpes-Côte d’Azur',
    postalCode: '13200',
    addressCountry: 'FR',
  },
  areaServed: localServiceAreas.map((name) => ({ '@type': 'City', name })),
  openingHoursSpecification: [
    {
      '@type': 'OpeningHoursSpecification',
      dayOfWeek: ['Monday', 'Tuesday', 'Wednesday', 'Thursday', 'Friday'],
      opens: '08:00',
      closes: '20:00',
    },
    {
      '@type': 'OpeningHoursSpecification',
      dayOfWeek: 'Saturday',
      opens: '08:00',
      closes: '13:00',
    },
  ],
  sameAs: [infos?.data.reseaux.instagram, infos?.data.reseaux.facebook].filter(Boolean),
};
---

<!doctype html>
<html lang="fr">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="canonical" href={canonical} />

    <title>{title} | MFP Sport</title>
    <meta name="description" content={description} />
    {noindex && <meta name="robots" content="noindex, nofollow" />}

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={`${title} | MFP Sport`} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:locale" content="fr_FR" />

    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} is:inline />
  </head>
  <body>
    <Header />
    <main>
      <slot />
    </main>
    <Footer />

    <script>
      // Apparition au défilement des éléments .reveal / .reveal-stagger.
      const revealables = document.querySelectorAll('.reveal, .reveal-stagger');
      if (revealables.length > 0) {
        const io = new IntersectionObserver(
          (entries) => {
            for (const entry of entries) {
              if (entry.isIntersecting) {
                entry.target.classList.add('is-visible');
                io.unobserve(entry.target);
              }
            }
          },
          { threshold: 0.15 }
        );
        revealables.forEach((el) => io.observe(el));
      }
    </script>
  </body>
</html>
