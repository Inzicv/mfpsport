---
// Navigation principale — voir docs/etude-refonte.md §E et §G.4.
import { getEntry } from 'astro:content';
import { Image } from 'astro:assets';
import Cta from './Cta.astro';
import logo from '../assets/logo-mfp-sport.png';

const infos = await getEntry('infos', 'infos-pratiques');

const poles = [
  { href: '/preparation-physique/', label: 'Entraînement' },
  { href: '/nutrition/', label: 'Nutrition' },
  { href: '/recuperation/', label: 'Récupération' },
  { href: '/preparation-mentale/', label: 'Mental' },
];

const nav = [
  { href: '/le-centre/', label: 'Le centre' },
  { href: '/preparation-physique/', label: 'Nos pôles', children: poles },
  { href: '/equipe/', label: "L'équipe" },
  { href: '/tarifs/', label: 'Tarifs' },
  { href: '/planning/', label: 'Planning' },
  { href: '/equipes-clubs/', label: 'Équipes & clubs' },
  { href: '/contact/', label: 'Contact' },
];
---

<header class="site-header" data-header>
  <div class="site-header__bar">
    <a href="/" class="site-header__logo" aria-label="MFP Sport — accueil">
      <Image src={logo} alt="MFP Sport" height={66} widths={[100, 140, 200]} loading="eager" />
    </a>

    <nav class="site-header__nav" aria-label="Navigation principale">
      <ul>
        {
          nav.map((item) => (
            <li class:list={['nav-item', { 'has-children': item.children }]}>
              <a href={item.href} aria-haspopup={item.children ? 'true' : undefined}>
                {item.label}
                {item.children && <span class="chevron" aria-hidden="true">▾</span>}
              </a>
              {item.children && (
                <ul class="submenu">
                  {item.children.map((child) => (
                    <li>
                      <a href={child.href}>{child.label}</a>
                    </li>
                  ))}
                </ul>
              )}
            </li>
          ))
        }
      </ul>
    </nav>

    <div class="site-header__actions">
      {infos && (
        <a class="espace-client" href={infos.data.lienEspaceClient} rel="noopener">
          Espace client
        </a>
      )}
      <Cta class="cta--sm" />
    </div>

    <button class="burger" aria-label="Ouvrir le menu" aria-expanded="false" data-burger>
      <span></span><span></span><span></span>
    </button>
  </div>

  <!-- Panneau mobile -->
  <div class="mobile-panel" data-panel hidden>
    <nav aria-label="Navigation mobile">
      <ul>
        {
          nav.map((item) => (
            <li>
              <a href={item.href}>{item.label}</a>
              {item.children && (
                <ul>
                  {item.children.map((child) => (
                    <li><a href={child.href}>{child.label}</a></li>
                  ))}
                </ul>
              )}
            </li>
          ))
        }
      </ul>
    </nav>
    <div class="mobile-panel__actions">
      <Cta />
      {infos && (
        <a class="espace-client" href={infos.data.lienEspaceClient} rel="noopener">
          Espace client
        </a>
      )}
    </div>
  </div>
</header>

<script>
  const burger = document.querySelector('[data-burger]');
  const panel = document.querySelector('[data-panel]');
  const header = document.querySelector('[data-header]');

  burger?.addEventListener('click', () => {
    const open = burger.getAttribute('aria-expanded') === 'true';
    burger.setAttribute('aria-expanded', String(!open));
    burger.setAttribute('aria-label', open ? 'Ouvrir le menu' : 'Fermer le menu');
    if (panel) (panel as HTMLElement).hidden = open;
    document.body.style.overflow = open ? '' : 'hidden';
  });

  // Ombre du header au défilement
  const onScroll = () => header?.classList.toggle('is-scrolled', window.scrollY > 8);
  onScroll();
  window.addEventListener('scroll', onScroll, { passive: true });
</script>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 50;
    background: rgba(255, 255, 255, 0.96);
    backdrop-filter: saturate(120%) blur(14px);
    border-bottom: 1px solid transparent;
    transition: border-color 0.2s ease, box-shadow 0.2s ease;
  }

  .site-header.is-scrolled {
    border-bottom-color: var(--color-line);
    box-shadow: var(--shadow-sm);
  }

  .site-header__bar {
    display: flex;
    align-items: center;
    gap: 1.5rem;
    max-width: var(--maxw);
    margin-inline: auto;
    min-height: 84px;
    padding: 0.55rem clamp(1.1rem, 4vw, 3rem);
  }

  .site-header__logo {
    display: inline-flex;
    align-items: center;
    margin-right: auto;
  }

  .site-header__logo :global(img) {
    height: 66px;
    width: auto;
  }

  .site-header__nav > ul {
    display: flex;
    gap: 0;
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .nav-item {
    position: relative;
  }

  .nav-item > a {
    display: inline-flex;
    align-items: center;
    gap: 0.25rem;
    padding: 0.65rem 0.62rem;
    border-radius: 0;
    color: var(--color-blue-night);
    text-decoration: none;
    font-size: 0.88rem;
    font-weight: 600;
    white-space: nowrap;
    transition: background-color 0.15s ease, color 0.15s ease;
  }

  .nav-item > a:hover {
    background: transparent;
    color: var(--color-blue-deep);
    box-shadow: inset 0 -2px var(--color-blue-deep);
  }

  .chevron {
    font-size: 0.7em;
    opacity: 0.7;
  }

  /* Sous-menu : masqué par défaut, affiché au survol/focus (bug de spécificité corrigé) */
  .submenu {
    display: flex;
    position: absolute;
    top: calc(100% - 1px);
    left: 0;
    flex-direction: column;
    gap: 2px;
    min-width: 13rem;
    list-style: none;
    margin: 0;
    padding: 0.5rem;
    background: var(--color-surface);
    border: 1px solid var(--color-line);
    box-shadow: var(--shadow-card);
    border-radius: var(--radius-sm);
    z-index: 100;
    opacity: 0;
    visibility: hidden;
    pointer-events: none;
    transform: translateY(5px);
    transition: opacity 0.16s ease, transform 0.16s ease, visibility 0.16s;
  }

  .nav-item.has-children:hover .submenu,
  .nav-item.has-children:focus-within .submenu {
    opacity: 1;
    visibility: visible;
    pointer-events: auto;
    transform: translateY(0);
  }

  .submenu a {
    display: block;
    padding: 0.55rem 0.75rem;
    border-radius: var(--radius-sm);
    color: var(--color-blue-night);
    text-decoration: none;
    font-size: 0.92rem;
  }

  .submenu a:hover {
    background: rgba(0, 92, 169, 0.08);
    color: var(--color-blue-deep);
  }

  .site-header__actions {
    display: flex;
    align-items: center;
    gap: 1rem;
  }

  .espace-client {
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--color-slate);
    text-decoration: none;
    white-space: nowrap;
  }

  .espace-client:hover {
    color: var(--color-blue-deep);
  }

  :global(.cta--sm) {
    padding: 0.6em 1.25em !important;
    font-size: 0.9rem !important;
  }

  /* Burger */
  .burger {
    display: none;
    flex-direction: column;
    gap: 5px;
    width: 44px;
    height: 44px;
    align-items: center;
    justify-content: center;
    background: none;
    border: 1px solid var(--color-line);
    border-radius: var(--radius-sm);
    cursor: pointer;
  }

  .burger span {
    width: 20px;
    height: 2px;
    background: var(--color-blue-night);
    border-radius: 2px;
  }

  .mobile-panel {
    border-top: 1px solid var(--color-line);
    background: var(--color-surface);
    padding: 1rem clamp(1.1rem, 4vw, 3rem) 2rem;
  }

  .mobile-panel nav ul {
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .mobile-panel > nav > ul > li > a {
    display: block;
    padding: 0.75rem 0;
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 1.1rem;
    color: var(--color-blue-night);
    text-decoration: none;
    border-bottom: 1px solid var(--color-line);
  }

  .mobile-panel ul ul {
    padding: 0.25rem 0 0.5rem 1rem;
  }

  .mobile-panel ul ul a {
    display: block;
    padding: 0.4rem 0;
    color: var(--color-slate);
    text-decoration: none;
  }

  .mobile-panel__actions {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    align-items: flex-start;
    margin-top: 1.5rem;
  }

  @media (max-width: 960px) {
    .site-header__nav,
    .site-header__actions {
      display: none;
    }
    .burger {
      display: flex;
    }
    .site-header__bar {
      min-height: 72px;
    }
    .site-header__logo :global(img) {
      height: 56px;
    }
  }

  @media (min-width: 961px) {
    .mobile-panel {
      display: none;
    }
  }
</style>
