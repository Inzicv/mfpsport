---
// Affiche les professionnels actifs rattachés à un pôle (par spécialité).
// Utilisé sur les pages de pôles pour renvoyer un visage sur « qui va
// m'accompagner ? » — voir docs/etude-refonte.md §A.5 et §F.
import { getCollection } from 'astro:content';
import ProContacts from './ProContacts.astro';

interface Props {
  specialite: string;
  titre?: string;
}

const { specialite, titre = 'Qui vous accompagne' } = Astro.props;

const pros = (await getCollection('professionnels'))
  .filter((p) => p.data.actif && p.data.specialites.includes(specialite))
  .sort((a, b) => a.data.ordre - b.data.ordre);
---

{
  pros.length > 0 && (
    <div class="polepros">
      <h2>{titre}</h2>
      <ul>
        {pros.map((p) => (
          <li>
            <p class="polepros__nom">{p.data.nom}</p>
            <p class="polepros__role">{p.data.role}</p>
            <a href="/equipe/">Voir sa fiche</a>
            <ProContacts
              compact
              telephone={p.data.telephone}
              email={p.data.email}
              lienRdv={p.data.lienRdv}
              instagram={p.data.instagram}
              facebook={p.data.facebook}
              linkedin={p.data.linkedin}
            />
          </li>
        ))}
      </ul>
    </div>
  )
}

<style>
  .polepros {
    max-width: 52rem;
    margin-top: 3.5rem;
  }

  .polepros ul {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    gap: 0;
    list-style: none;
    padding: 0;
    border-top: 1px solid var(--color-line);
  }

  .polepros li {
    border-bottom: 1px solid var(--color-line);
    padding: 1.25rem 0;
  }

  .polepros__nom {
    font-family: var(--font-heading);
    font-weight: 600;
    color: var(--color-blue-night);
    margin: 0;
  }

  .polepros__role {
    color: var(--color-blue-deep);
    font-size: 0.9rem;
    margin: 0.25rem 0 0.75rem;
  }
</style>
