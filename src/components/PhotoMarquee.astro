---
// Bande de photos défilante (marquee CSS infini, pause au survol,
// dégradation en défilement manuel si prefers-reduced-motion).
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';

interface Props {
  images: { src: ImageMetadata; alt: string }[];
}

const { images } = Astro.props;
---

<div class="marquee photo-marquee" aria-label="Photos de la salle MFP Sport">
  {
    /* La piste est dupliquée pour un défilement en boucle continue ;
       la copie est masquée aux lecteurs d'écran. */
  }
  <ul class="marquee__track">
    {
      images.map((img) => (
        <li>
          <Image src={img.src} alt={img.alt} widths={[320, 480]} sizes="300px" height={340} />
        </li>
      ))
    }
  </ul>
  <ul class="marquee__track" aria-hidden="true">
    {
      images.map((img) => (
        <li>
          <Image src={img.src} alt="" widths={[320, 480]} sizes="300px" height={340} />
        </li>
      ))
    }
  </ul>
</div>

<style>
  .photo-marquee {
    gap: 1rem;
    padding-block: 0.5rem;
  }

  .photo-marquee ul {
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .photo-marquee li {
    flex-shrink: 0;
  }

  .photo-marquee :global(img) {
    height: min(300px, 38vw);
    width: auto;
    border-radius: var(--radius-md);
    display: block;
  }
</style>
