---
// Widget Sportigo — chargement différé pour préserver les Core Web Vitals.
// Voir docs/etude-refonte.md §D.1 et §H.9.
import Layout from '../layouts/Layout.astro';
import SportigoPlanning from '../components/SportigoPlanning.astro';
---

<Layout
  title="Planning & réservation"
  description="Consultez le planning des cours collectifs MFP Sport à Arles et réservez directement en ligne."
>
  <header class="page-hero">
    <p class="eyebrow eyebrow--light">Réserver en ligne</p>
    <h1>Planning &amp; réservation</h1>
    <p>Choisissez votre séance et réservez votre place directement auprès du centre.</p>
  </header>
  <section class="page planning-page">
    <SportigoPlanning />
  </section>
</Layout>

<style>
  .page {
    max-width: var(--maxw);
    margin: 0 auto;
    padding: clamp(2rem, 6vw, 4rem) clamp(1rem, 4vw, 3rem);
  }
</style>
