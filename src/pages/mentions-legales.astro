---
// Mentions légales (obligation LCEN). Données confirmées : SIRET, adresse,
// hébergeur. Les éléments marqués « à confirmer » attendent une validation de
// Maxime (§B.2) — forme juridique, RCS, capital, directeur de la publication.
import Layout from '../layouts/Layout.astro';
import { getEntry } from 'astro:content';

const infos = await getEntry('infos', 'infos-pratiques');
---

<Layout
  title="Mentions légales"
  description="Mentions légales du site MFP Sport, 15 Chemin des Moines, 13200 Arles."
  noindex
>
  <div class="page prose">
    <h1>Mentions légales</h1>

    <h2>Éditeur du site</h2>
    <p>
      <strong>MFP Sport</strong><br />
      15 Chemin des Moines, 13200 Arles, France<br />
      SIRET : 981 625 783 00015 — SIREN : 981 625 783<br />
      {infos && (
        <>Téléphone : {infos.data.telephone}<br />E-mail : {infos.data.email}</>
      )}
    </p>
    <p>
      <em>
        À compléter avant mise en production : forme juridique, capital social (le cas
        échéant), numéro RCS et ville d'immatriculation, et numéro de TVA intracommunautaire.
      </em>
    </p>

    <h2>Directeur de la publication</h2>
    <p>Maxime Favier.</p>

    <h2>Hébergement</h2>
    <p>
      Le site est hébergé par <strong>OVH SAS</strong><br />
      2 rue Kellermann, 59100 Roubaix, France<br />
      Téléphone : 1007<br />
      <a href="https://www.ovhcloud.com" rel="noopener">www.ovhcloud.com</a>
    </p>

    <h2>Propriété intellectuelle</h2>
    <p>
      L'ensemble des contenus présents sur ce site (textes, images, logo, éléments graphiques)
      est la propriété de MFP Sport, sauf mention contraire, et ne peut être reproduit sans
      autorisation préalable.
    </p>

    <h2>Réservations et paiements</h2>
    <p>
      Les inscriptions, réservations et paiements sont gérés par la plateforme externe
      Sportigo. Les conditions applicables sont celles de Sportigo, accessibles depuis les
      espaces de réservation et l'espace client.
    </p>

    <h2>Données personnelles</h2>
    <p>
      Le traitement de vos données est décrit dans notre
      <a href="/politique-de-confidentialite/">politique de confidentialité</a>.
    </p>
  </div>
</Layout>
