---
import Layout from '../layouts/Layout.astro';
import Cta from '../components/Cta.astro';
import Galerie from '../components/Galerie.astro';
import { Image } from 'astro:assets';
import vertimax from '../assets/images/entrainement-vertimax-mfp-sport.jpg';
import plan from '../assets/images/plan-salle-mfp-sport-arles.jpg';
import keiser from '../assets/images/entrainement-keiser-mfp-sport.jpg';
import cryotank from '../assets/images/recuperation-cryotank-mfp-sport.jpg';
import testForce from '../assets/images/preparateur-physique-test-force.jpg';
import sprint from '../assets/images/preparation-physique-sprint-arles.jpg';
import halteres from '../assets/images/halteres-logo-mfp-sport.jpg';
import sac from '../assets/images/sac-de-frappe-cross-training.jpg';
import velos from '../assets/images/velos-wattbike-keiser-cardio.jpg';
import elliptique from '../assets/images/elliptique-sparc-cardio.jpg';
import zoneCardio from '../assets/images/zone-cardio-mfp-sport.jpg';
import tirage from '../assets/images/coaching-tirage-poulie.jpg';
import kinvent from '../assets/images/test-force-dynamometre-kinvent.jpg';
import kbox from '../assets/images/squat-kbox-exxentric.jpg';
import vertimaxSprint from '../assets/images/vertimax-preparation-sprint.jpg';
import accessoires from '../assets/images/accessoires-cours-collectifs.jpg';
import vueEnsemble from '../assets/images/vue-ensemble-piste-materiel.jpg';
import vueRameur from '../assets/images/vue-ensemble-rameur-skierg.jpg';
import zoneVelos from '../assets/images/zone-velos-spinning-mur.jpg';
import coursEtirements from '../assets/images/cours-collectif-etirements-sol.jpg';
import coursSpinning from '../assets/images/cours-collectif-spinning-steps.jpg';
import coachingDeadlift from '../assets/images/coaching-souleve-de-terre.jpg';
import coachingVertimax from '../assets/images/coaching-vertimax-explosivite.jpg';
import cryotankDuo from '../assets/images/cryotank-bain-froid-duo.jpg';
import communaute from '../assets/images/communaute-adherents-mfp-sport.jpg';

const galerie = [
  { src: vueEnsemble, alt: "Vue d'ensemble de la piste et du plateau technique" },
  { src: communaute, alt: 'Un groupe d’adhérents MFP Sport devant la fresque du centre' },
  { src: halteres, alt: "Le rack d'haltères et le logo MFP Sport au sol" },
  { src: coachingVertimax, alt: "Coaching sur VertiMax pour l'explosivité" },
  { src: keiser, alt: 'Entraînement sur machine Keiser à MFP Sport, Arles' },
  { src: coursEtirements, alt: 'Cours collectif au sol chez MFP Sport' },
  { src: velos, alt: 'Vélos Wattbike Pro et Keiser M3i de la zone cardio' },
  { src: cryotankDuo, alt: 'Deux membres en séance de récupération au Cryo-Tank' },
  { src: coachingDeadlift, alt: 'Coaching individuel, soulevé de terre' },
  { src: tirage, alt: 'Coaching : tirage poulie avec dynamomètre' },
  { src: vueRameur, alt: 'Zone rameur et SkiErg devant la fresque MFP Sport' },
  { src: sac, alt: 'Sac de frappe et disques de la zone cross-training' },
  { src: testForce, alt: 'Test de force avec un préparateur physique' },
  { src: coursSpinning, alt: 'Cours collectif : spinning et steps' },
  { src: elliptique, alt: 'Vélo elliptique Sparc de la zone cardio' },
  { src: kinvent, alt: 'Mesure de force avec capteur Kinvent' },
  { src: zoneVelos, alt: 'Rangée de vélos de spinning devant la fresque MFP Sport' },
  { src: sprint, alt: "Sprint résisté sur la piste d'athlétisme intérieure" },
  { src: kbox, alt: 'Squat harnais sur K Box Exxentric' },
  { src: zoneCardio, alt: 'Vue de la zone cardio de la salle' },
  { src: vertimaxSprint, alt: 'Préparation de sprint sur VertiMax' },
  { src: accessoires, alt: 'Steps, swiss balls et accessoires des cours collectifs' },
];
---

<Layout
  title="Le centre — 300 m² dédiés à la performance à Arles"
  description="Découvrez MFP Sport à Arles : 300 m² d'espace d'entraînement, piste d'athlétisme, zone fonctionnelle et équipements haute performance pour tous les niveaux."
>
  <header class="page-hero">
    <h1>Un centre pensé pour la performance et l'accompagnement</h1>
    <p>
      300 m² dédiés à l'entraînement, à la récupération et au suivi, à Arles — bien plus
      qu'une simple salle de sport.
    </p>
  </header>

  <main class="centre-page">
    <p class="centre-intro">
      MFP Sport n'est pas une salle en libre-service de plus. C'est un environnement complet
      où chaque personne peut être évaluée, conseillée, entraînée et accompagnée dans sa
      récupération, quel que soit son niveau de départ.
    </p>

    <section class="centre-feature">
      <div>
        <p class="eyebrow">L'espace</p>
        <h2>300 m² dédiés à la pratique sportive</h2>
        <p>
          La salle dispose d'une vaste zone de travail de près de 300 m² en sol souple, idéale
          pour des entraînements variés en toute sécurité. Vous y trouverez aussi une piste
          d'athlétisme de 24 m pour les sprints et les exercices de vitesse, ainsi qu'une zone
          fonctionnelle de 57 m² en pelouse synthétique haute performance.
        </p>
      </div>
      <Image
        class="centre-feature__image"
        src={plan}
        alt="Plan de la salle MFP Sport à Arles : zone d'entraînement, piste, zone fonctionnelle et box praticiens"
        widths={[640, 960]}
        sizes="(max-width: 800px) 100vw, 52vw"
      />
    </section>

    <section class="centre-tools" aria-label="Les équipements du centre">
      <article>
        <span>01</span>
        <h2>Les outils de musculation</h2>
        <p>
          Half Rack WIIT Pro, cage de cross-training à trois stations, Kieser fonctionnel,
          barres Bamboo BANDBELL, sac de frappe, plyo box et corde ondulatoire.
        </p>
      </article>
      <article>
        <span>02</span>
        <h2>Les outils cardio</h2>
        <p>
          SkiErg et RowErg Concept 2, Wattbike Pro, vélos de spinning M3i et elliptiques
          Sparc pour un travail intense qui préserve les articulations.
        </p>
      </article>
    </section>

    <section class="centre-feature centre-feature--reverse">
      <div>
        <p class="eyebrow">Performance</p>
        <h2>Des outils qui vont plus loin</h2>
        <p>
          VertiMax pour la force et l'explosivité, poulies magnétiques Voltra, Battle4Run The
          Crab, BlazePods pour la réactivité et K Box4 pour l'entraînement excentrique : le
          matériel sert une programmation précise, jamais l'inverse.
        </p>
      </div>
      <Image
        class="centre-feature__image"
        src={vertimax}
        alt="Entraînement sur VertiMax à MFP Sport, développement de l'explosivité"
        widths={[640, 960]}
        sizes="(max-width: 800px) 100vw, 52vw"
      />
    </section>

    <section class="centre-measure">
      <p class="eyebrow eyebrow--light">Mesurer pour progresser</p>
      <h2>Les outils de mesure et de tests</h2>
      <p>
        Les capteurs Kinvent et les encodeurs Vitruve permettent de suivre vos progrès,
        d'ajuster les entraînements et de personnaliser votre programme à partir de données
        concrètes.
      </p>
    </section>

    <Galerie titre="Le centre en images" images={galerie} />

    <div class="section-cta"><Cta /></div>
  </main>
</Layout>

<style>
  .centre-page {
    max-width: var(--maxw);
    margin-inline: auto;
    padding: clamp(3rem, 7vw, 6rem) clamp(1.1rem, 4vw, 3rem);
  }

  .centre-intro {
    max-width: 48rem;
    margin: 0 0 clamp(3rem, 7vw, 6rem);
    color: var(--color-blue-night);
    font-family: var(--font-display);
    font-size: clamp(1.3rem, 2.3vw, 1.75rem);
    line-height: 1.45;
  }

  .centre-feature {
    display: grid;
    grid-template-columns: minmax(0, .8fr) minmax(0, 1.2fr);
    gap: clamp(2rem, 6vw, 6rem);
    align-items: center;
    margin-bottom: clamp(4rem, 9vw, 8rem);
  }

  .centre-feature--reverse {
    grid-template-columns: minmax(0, 1.2fr) minmax(0, .8fr);
  }

  .centre-feature--reverse > div { grid-column: 2; grid-row: 1; }
  .centre-feature--reverse .centre-feature__image { grid-column: 1; grid-row: 1; }

  .centre-feature__image {
    width: 100%;
    max-height: 38rem;
    object-fit: cover;
    box-shadow: var(--shadow-card);
  }

  .centre-feature h2 { font-size: clamp(2.2rem, 4.3vw, 4rem); }
  .centre-feature p:last-child { color: var(--color-slate); }

  .centre-tools {
    display: grid;
    grid-template-columns: 1fr 1fr;
    margin-bottom: clamp(4rem, 9vw, 8rem);
    border-block: 1px solid var(--color-line);
  }

  .centre-tools article { padding: clamp(2rem, 5vw, 4rem); }
  .centre-tools article + article { border-left: 1px solid var(--color-line); }
  .centre-tools span { color: var(--color-blue-deep); font-family: var(--font-display); font-weight: 700; }
  .centre-tools h2 { margin-top: 1rem; font-size: clamp(1.8rem, 3vw, 2.8rem); }
  .centre-tools p { color: var(--color-slate); }

  .centre-measure {
    max-width: 56rem;
    margin: 0 auto clamp(4rem, 8vw, 7rem);
    padding: clamp(2.5rem, 6vw, 5rem);
    color: #d3e2eb;
    background: var(--color-blue-night);
  }

  .centre-measure h2 { color: #fff; }
  .centre-page :global(.galerie) { margin-top: 2rem; }
  .centre-page :global(.galerie > h2) { margin-bottom: 1.5rem; }

  @media (max-width: 800px) {
    .centre-feature,
    .centre-feature--reverse,
    .centre-tools { grid-template-columns: 1fr; }
    .centre-feature--reverse > div,
    .centre-feature--reverse .centre-feature__image { grid-column: 1; grid-row: auto; }
    .centre-tools article + article { border-left: 0; border-top: 1px solid var(--color-line); }
  }
</style>
