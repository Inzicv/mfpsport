---
import Layout from '../layouts/Layout.astro';
import { getCollection, render } from 'astro:content';
import { Image } from 'astro:assets';

const pros = (await getCollection('professionnels'))
  .filter((p) => p.data.actif)
  .sort((a, b) => a.data.ordre - b.data.ordre);

const rendus = await Promise.all(
  pros.map(async (p) => ({ data: p.data, Content: (await render(p)).Content }))
);

const initiales = (nom: string) =>
  nom
    .split(' ')
    .map((m) => m[0])
    .join('')
    .slice(0, 2)
    .toUpperCase();
---

<Layout
  title="L'équipe"
  description="Rencontrez l'équipe pluridisciplinaire de MFP Sport à Arles : coach, préparateur physique, diététicienne, préparateur mental, ostéopathe, praticienne massage."
>
  <section class="page">
    <h1>L'équipe</h1>
    <p class="intro">
      Chez MFP Sport, vous n'êtes jamais seul·e face aux machines. Une équipe de
      professionnels vous évalue, vous conseille et vous accompagne à chaque étape.
    </p>

    {
      rendus.length === 0 ? (
        <p><em>Fiches de l'équipe en préparation.</em></p>
      ) : (
        <ul class="equipe__grid">
          {rendus.map(({ data, Content }) => (
            <li class="pro">
              {data.photo ? (
                <Image
                  class="pro__photo"
                  src={data.photo}
                  alt={`${data.nom}, ${data.role} chez MFP Sport`}
                  width={120}
                  height={120}
                />
              ) : (
                <span class="pro__photo pro__photo--placeholder" aria-hidden="true">
                  {initiales(data.nom)}
                </span>
              )}
              <h2>{data.nom}</h2>
              <p class="pro__role">{data.role}</p>
              {data.diplomes.length > 0 && (
                <ul class="pro__diplomes">
                  {data.diplomes.map((d) => (
                    <li>{d}</li>
                  ))}
                </ul>
              )}
              <div class="pro__bio">
                <Content />
              </div>
              {data.joursPresence && <p class="pro__presence">📅 {data.joursPresence}</p>}
            </li>
          ))}
        </ul>
      )
    }
  </section>
</Layout>

<style>
  .page {
    max-width: 60rem;
    margin: 0 auto;
    padding: clamp(2rem, 6vw, 4rem) clamp(1rem, 4vw, 3rem);
  }

  .intro {
    max-width: 50ch;
    color: var(--color-slate);
  }

  .equipe__grid {
    display: grid;
    gap: 1.5rem;
    list-style: none;
    padding: 0;
    margin-top: 2rem;
  }

  .pro {
    background: #fff;
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-card);
    padding: 1.75rem;
  }

  .pro__photo {
    width: 120px;
    height: 120px;
    border-radius: 50%;
    object-fit: cover;
    margin-bottom: 1rem;
  }

  .pro__photo--placeholder {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    background: var(--color-blue-night);
    color: #fff;
    font-family: var(--font-heading);
    font-size: 2rem;
    font-weight: 700;
  }

  .pro__role {
    color: var(--color-blue-deep);
    font-weight: 600;
    margin-top: -0.25rem;
  }

  .pro__diplomes {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
    padding: 0;
    margin: 0 0 1rem;
    list-style: none;
  }

  .pro__diplomes li {
    background: var(--color-paper);
    color: var(--color-blue-night);
    font-size: 0.8rem;
    padding: 0.2rem 0.6rem;
    border-radius: 999px;
  }

  .pro__bio :global(p) {
    margin: 0 0 0.75rem;
  }

  .pro__presence {
    color: var(--color-slate);
    font-size: 0.9rem;
    margin-bottom: 0;
  }
</style>
