---
import Layout from '../layouts/Layout.astro';
import { getCollection, render } from 'astro:content';
import { Image } from 'astro:assets';
import ProContacts from '../components/ProContacts.astro';

const pros = (await getCollection('professionnels'))
  .filter((p) => p.data.actif)
  .sort((a, b) => a.data.ordre - b.data.ordre);

const rendus = await Promise.all(
  pros.map(async (p) => ({ data: p.data, Content: (await render(p)).Content }))
);

const initiales = (nom: string) =>
  nom
    .split(' ')
    .map((m) => m[0])
    .join('')
    .slice(0, 2)
    .toUpperCase();
---

<Layout
  title="L'équipe"
  description="Rencontrez l'équipe pluridisciplinaire de MFP Sport à Arles : coach, préparateur physique, diététicienne, préparateur mental, ostéopathe, praticienne massage."
>
  <header class="page-hero equipe-hero">
    <p class="eyebrow eyebrow--light">Une équipe, un même parcours</p>
    <h1>Les professionnels qui vous accompagnent</h1>
    <p>
      Chez MFP Sport, vous n'êtes jamais seul·e face aux machines. Une équipe de
      professionnels vous évalue, vous conseille et vous accompagne à chaque étape.
    </p>
  </header>

  <section class="page equipe-page">

    {
      rendus.length === 0 ? (
        <p><em>Fiches de l'équipe en préparation.</em></p>
      ) : (
        <ul class="equipe__grid">
          {rendus.map(({ data, Content }) => (
            <li class="pro">
              {data.photo ? (
                <Image
                  class="pro__photo"
                  src={data.photo}
                  alt={`${data.nom}, ${data.role} chez MFP Sport`}
                  width={720}
                  height={540}
                />
              ) : (
                <span class="pro__photo pro__photo--placeholder" aria-hidden="true">
                  {initiales(data.nom)}
                </span>
              )}
              <h2>{data.nom}</h2>
              <p class="pro__role">{data.role}</p>
              {data.diplomes.length > 0 && (
                <ul class="pro__diplomes">
                  {data.diplomes.map((d) => (
                    <li>{d}</li>
                  ))}
                </ul>
              )}
              <div class="pro__bio">
                <Content />
              </div>
              {data.joursPresence && <p class="pro__presence">Présence : {data.joursPresence}</p>}
              <ProContacts
                telephone={data.telephone}
                email={data.email}
                lienRdv={data.lienRdv}
                instagram={data.instagram}
                facebook={data.facebook}
                linkedin={data.linkedin}
              />
            </li>
          ))}
        </ul>
      )
    }
  </section>
</Layout>

<style>
  .page {
    max-width: var(--maxw);
    margin: 0 auto;
    padding: clamp(2rem, 6vw, 4rem) clamp(1rem, 4vw, 3rem);
  }

  .equipe-hero {
    text-align: left;
  }

  .equipe-hero h1,
  .equipe-hero p {
    margin-inline: 0;
  }

  .equipe-hero > * {
    max-width: min(72rem, calc(100% - 2.2rem));
    margin-left: max(1.1rem, calc((100% - 72rem) / 2));
  }

  .equipe__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.25rem;
    list-style: none;
    padding: 0;
    margin-top: 2rem;
  }

  .pro {
    display: grid;
    grid-template-columns: minmax(15rem, 22rem) minmax(0, 1fr);
    grid-template-rows: auto;
    column-gap: clamp(1.5rem, 4vw, 3.5rem);
    align-items: start;
    background: #fff;
    border: 1px solid var(--color-line);
    padding: clamp(1.5rem, 4vw, 2.5rem);
  }

  .pro > :not(.pro__photo) {
    grid-column: 2;
  }

  .pro__photo {
    grid-column: 1;
    grid-row: 1 / span 8;
    width: 100%;
    height: auto;
    aspect-ratio: 4 / 3;
    border-radius: var(--radius-sm);
    object-fit: cover;
    margin-bottom: 1rem;
  }

  .pro:nth-child(even) {
    grid-template-columns: minmax(0, 1fr) minmax(15rem, 22rem);
  }

  .pro:nth-child(even) > :not(.pro__photo) {
    grid-column: 1;
  }

  .pro:nth-child(even) .pro__photo {
    grid-column: 2;
  }

  .pro__photo--placeholder {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    background: var(--color-blue-night);
    color: #fff;
    font-family: var(--font-heading);
    font-size: 2rem;
    font-weight: 700;
  }

  .pro__role {
    color: var(--color-blue-deep);
    font-weight: 600;
    margin-top: -0.25rem;
  }

  .pro__diplomes {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
    padding: 0;
    margin: 0 0 1rem;
    list-style: none;
  }

  .pro__diplomes li {
    background: var(--color-paper);
    color: var(--color-blue-night);
    font-size: 0.8rem;
    padding: 0.2rem 0.6rem;
    border-radius: 999px;
  }

  .pro__bio :global(p) {
    margin: 0 0 0.75rem;
  }

  .pro__presence {
    color: var(--color-slate);
    font-size: 0.9rem;
    margin-bottom: 0;
  }

  @media (max-width: 720px) {
    .pro,
    .pro:nth-child(even) {
      grid-template-columns: 1fr;
    }

    .pro > :not(.pro__photo),
    .pro:nth-child(even) > :not(.pro__photo),
    .pro__photo,
    .pro:nth-child(even) .pro__photo {
      grid-column: 1;
    }

    .pro__photo,
    .pro:nth-child(even) .pro__photo {
      grid-row: auto;
    }
  }
</style>
