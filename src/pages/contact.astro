---
import Layout from '../layouts/Layout.astro';
import Cta from '../components/Cta.astro';
import { getEntry } from 'astro:content';

const infos = await getEntry('infos', 'infos-pratiques');
const data = infos!.data;

// Lien d'itinéraire vers OpenStreetMap (sans traceur) à partir de l'adresse.
const adresseUrl = encodeURIComponent(data.adresse);
const mapUrl = `https://www.openstreetmap.org/search?query=${adresseUrl}`;
---

<Layout
  title="Contact & accès"
  description="Contactez MFP Sport à Arles : 15 Chemin des Moines, horaires, accès et prise de rendez-vous. Réservez votre bilan gratuit."
>
  <header class="page-hero">
    <h1>Nous contacter</h1>
    <p>
      Une question, une visite, un projet d'équipe ? Nous sommes à votre disposition — et le
      plus simple reste de réserver votre bilan gratuit.
    </p>
  </header>

  <div class="page contact">
    <div class="contact__col">
      <h2>Le centre</h2>
      <address>
        <strong>MFP Sport</strong><br />
        {data.adresse}<br />
        <a href={`mailto:${data.email}`}>{data.email}</a>
        {data.telephone && (
          <>
            <br />
            <a href={`tel:${data.telephone}`}>{data.telephone}</a>
          </>
        )}
      </address>

      <p class="contact__actions">
        <a class="cta" href={`mailto:${data.email}`}>Écrire un e-mail</a>
        <a class="link" href={mapUrl} rel="noopener">Voir l'itinéraire</a>
      </p>

      <h2>Horaires</h2>
      <ul class="contact__horaires">
        {
          data.horaires.map((h) => (
            <li>
              <span>{h.jour}</span>
              <span>{h.plage}</span>
            </li>
          ))
        }
      </ul>
    </div>

    <div class="contact__col">
      <h2>Réserver</h2>
      <p>
        Les réservations et inscriptions se font via Sportigo. Pour une première venue,
        réservez votre séance d'essai : elle est offerte et sans engagement.
      </p>
      <p><Cta /></p>
      <p>
        Déjà membre ? <a href={data.lienEspaceClient} rel="noopener">Accéder à votre espace client</a>.
      </p>

      <h2>Vous représentez une équipe ?</h2>
      <p>
        Clubs, équipes pros et semi-pros : découvrez nos offres de préparation collective sur
        la page <a href="/equipes-clubs/">Équipes &amp; clubs</a> et demandez un devis.
      </p>
    </div>
  </div>
</Layout>

<style>
  .contact {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 2.5rem;
  }

  .contact address {
    font-style: normal;
    line-height: 1.9;
  }

  .contact__actions {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 1rem;
    margin: 1.5rem 0 2rem;
  }

  .link {
    font-weight: 600;
  }

  .contact__horaires {
    list-style: none;
    padding: 0;
    max-width: 22rem;
  }

  .contact__horaires li {
    display: flex;
    justify-content: space-between;
    padding: 0.4rem 0;
    border-bottom: 1px solid rgba(11, 39, 64, 0.08);
  }
</style>
