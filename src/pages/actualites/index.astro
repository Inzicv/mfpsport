---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';
import { Image } from 'astro:assets';

const actualites = (await getCollection('actualites'))
  .filter((a) => a.data.publie)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
---

<Layout title="Actualités" description="Les actualités de MFP Sport à Arles : nouveautés, équipements, vie du centre.">
  <header class="page-hero">
    <h1>La vie du centre</h1>
    <p>Nouveautés, équipements, événements : ce qui se passe chez MFP Sport.</p>
  </header>

  <section class="page">
    {
      actualites.length === 0 ? (
        <p><em>Aucune actualité publiée pour le moment.</em></p>
      ) : (
        <ul class="actus-liste reveal-stagger">
          {actualites.map((a) => (
            <li>
              <a class="card actu" href={`/actualites/${a.id}/`}>
                {a.data.image && (
                  <Image
                    class="actu__img"
                    src={a.data.image}
                    alt={a.data.imageAlt ?? ''}
                    widths={[360, 560]}
                    sizes="(max-width: 40rem) 90vw, 340px"
                  />
                )}
                <div class="actu__body">
                  <p class="actu__date">
                    {a.data.date.toLocaleDateString('fr-FR', { day: 'numeric', month: 'long', year: 'numeric' })}
                  </p>
                  <h2>{a.data.titre}</h2>
                  <p class="actu__chapo">{a.data.chapo}</p>
                  <span class="actu__link">Lire l'article →</span>
                </div>
              </a>
            </li>
          ))}
        </ul>
      )
    }
  </section>
</Layout>

<style>
  .actus-liste {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: 1.5rem;
    list-style: none;
    padding: 0;
  }

  .actu {
    display: flex;
    flex-direction: column;
    height: 100%;
    text-decoration: none;
    color: var(--color-ink);
    overflow: hidden;
    transition: transform 0.18s ease, box-shadow 0.18s ease;
  }

  .actu:hover {
    transform: translateY(-4px);
    box-shadow: var(--shadow-lg);
  }

  .actu__img {
    width: 100%;
    height: 200px;
    object-fit: cover;
  }

  .actu__body {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
    padding: 1.25rem 1.5rem 1.5rem;
    flex: 1;
  }

  .actu__body h2 {
    font-size: 1.25rem;
    margin: 0;
  }

  .actu__date {
    font-size: 0.8rem;
    color: var(--color-slate);
    margin: 0;
  }

  .actu__chapo {
    color: var(--color-slate);
    font-size: 0.95rem;
    margin: 0;
  }

  .actu__link {
    margin-top: auto;
    padding-top: 0.5rem;
    font-weight: 600;
    color: var(--color-blue-deep);
  }
</style>
