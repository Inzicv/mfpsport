---
// Accueil — voir docs/etude-refonte.md §G.5 (structure revue le 14/07/2026 :
// hero split, bandeau chiffres supprimé, actus défilantes, vidéo, marquee photos).
import Layout from '../layouts/Layout.astro';
import Cta from '../components/Cta.astro';
import PhotoMarquee from '../components/PhotoMarquee.astro';
import { getCollection } from 'astro:content';
import { Image } from 'astro:assets';

import heroCoach from '../assets/images/coach-sportif-personnel-arles.jpg';
import heroHalteres from '../assets/images/halteres-logo-mfp-sport.jpg';
import mSac from '../assets/images/sac-de-frappe-cross-training.jpg';
import mVelos from '../assets/images/velos-wattbike-keiser-cardio.jpg';
import mElliptique from '../assets/images/elliptique-sparc-cardio.jpg';
import mCardio from '../assets/images/zone-cardio-mfp-sport.jpg';
import mTirage from '../assets/images/coaching-tirage-poulie.jpg';
import mKinvent from '../assets/images/test-force-dynamometre-kinvent.jpg';
import mUnilateral from '../assets/images/entrainement-unilateral-coach.jpg';
import mVertimax from '../assets/images/entrainement-vertimax-mfp-sport.jpg';
import mSprint from '../assets/images/vertimax-preparation-sprint.jpg';
import mKbox from '../assets/images/squat-kbox-exxentric.jpg';
import mCryo from '../assets/images/recuperation-cryotank-mfp-sport.jpg';
import mAccessoires from '../assets/images/accessoires-cours-collectifs.jpg';

const actualites = (await getCollection('actualites'))
  .filter((a) => a.data.publie)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const marqueeImages = [
  { src: mTirage, alt: 'Coaching personnel : tirage poulie encadré par le préparateur physique' },
  { src: mVelos, alt: 'Vélos Wattbike Pro et Keiser M3i de la zone cardio' },
  { src: mVertimax, alt: "Travail d'explosivité sur VertiMax" },
  { src: mSac, alt: 'Sac de frappe et disques de la zone cross-training' },
  { src: mKinvent, alt: 'Test de force avec dynamomètre Kinvent' },
  { src: mCryo, alt: 'Cryo-Tank pour la récupération par le froid' },
  { src: mUnilateral, alt: 'Entraînement unilatéral encadré par un coach' },
  { src: mElliptique, alt: 'Vélo elliptique Sparc de la zone cardio' },
  { src: mSprint, alt: 'Préparation de sprint sur VertiMax' },
  { src: mCardio, alt: 'Vue de la zone cardio de la salle' },
  { src: mKbox, alt: 'Squat harnais sur K Box Exxentric' },
  { src: mAccessoires, alt: 'Steps, swiss balls et accessoires des cours collectifs' },
];

const profils = [
  { titre: 'Je reprends le sport', texte: 'Après une longue pause ou un souci de santé, à votre rythme.', href: '/bilan-gratuit/' },
  { titre: 'Je veux me remettre en forme', texte: 'Perdre du poids, gagner en tonus et en énergie durablement.', href: '/preparation-physique/' },
  { titre: 'Je suis sportif', texte: 'Progresser dans ma discipline et passer un cap.', href: '/preparation-physique/' },
  { titre: 'Je représente une équipe', texte: 'Stages et préparation physique collective pour un club.', href: '/equipes-clubs/' },
];

const poles = [
  { numero: '01', nom: 'Entraînement', texte: 'Préparation physique et coaching personnel, équipements haute performance.', href: '/preparation-physique/' },
  { numero: '02', nom: 'Nutrition', texte: 'Suivi diététique du sportif, bilans et composition corporelle.', href: '/nutrition/' },
  { numero: '03', nom: 'Récupération', texte: 'Bains chaud/froid, pressothérapie, ostéopathie, massages.', href: '/recuperation/' },
  { numero: '04', nom: 'Mental', texte: 'Gestion du stress, concentration, préparation à la compétition.', href: '/preparation-mentale/' },
];

const etapes = [
  { titre: 'Votre bilan offert', texte: 'On évalue votre condition et on définit vos objectifs ensemble.' },
  { titre: 'Un programme personnalisé', texte: 'Adapté à votre niveau, vos objectifs et votre emploi du temps.' },
  { titre: 'Un suivi et des résultats', texte: 'Un accompagnement régulier et des progrès mesurés dans le temps.' },
];
---

<Layout
  title="Coach sportif personnel & salle de sport à Arles"
  description="MFP Sport à Arles : coach sportif personnel, préparation physique, nutrition, récupération et préparation mentale. Un accompagnement premium et humain — bilan gratuit offert."
>
  <!-- HERO SPLIT : texte + collage de vraies photos -->
  <section class="hero">
    <div class="container hero__grid">
      <div class="hero__text">
        <p class="eyebrow eyebrow--light">Arles · Alpilles · Camargue · Crau</p>
        <h1>Votre coach sportif personnel, dans une salle pensée pour progresser</h1>
        <p class="hero__lead">
          Préparation physique, nutrition, récupération et préparation mentale : un
          accompagnement premium et humain, quel que soit votre niveau de départ.
        </p>
        <div class="hero__actions">
          <Cta />
          <a class="btn-ghost" href="/le-centre/">Découvrir le centre</a>
        </div>
      </div>

      <div class="hero__visual" aria-hidden="true">
        <Image
          class="hero__photo hero__photo--main"
          src={heroCoach}
          alt=""
          loading="eager"
          widths={[420, 640]}
          sizes="(max-width: 900px) 70vw, 400px"
        />
        <Image
          class="hero__photo hero__photo--back"
          src={heroHalteres}
          alt=""
          loading="eager"
          widths={[320, 480]}
          sizes="(max-width: 900px) 45vw, 280px"
        />
        <p class="hero__badge">
          <span class="hero__badge-big">Bilan offert</span>
          <span>pour commencer, sans engagement</span>
        </p>
      </div>
    </div>
  </section>

  <!-- Bande photos défilante -->
  <section class="salle-mouvement" aria-label="La salle en images">
    <PhotoMarquee images={marqueeImages} />
  </section>

  <section class="section">
    <div class="container">
      <p class="eyebrow">Pour qui ?</p>
      <h2 class="reveal">Quel que soit votre point de départ</h2>
      <ul class="profils__grid reveal-stagger">
        {
          profils.map((p) => (
            <li>
              <a href={p.href} class="card profils__card">
                <span class="profils__titre">{p.titre}</span>
                <span class="profils__texte">{p.texte}</span>
                <span class="profils__arrow" aria-hidden="true">→</span>
              </a>
            </li>
          ))
        }
      </ul>
    </div>
  </section>

  <section class="section poles">
    <div class="container">
      <p class="eyebrow eyebrow--light">Notre approche</p>
      <h2 class="reveal">4 piliers de la réussite sportive</h2>
      <ul class="poles__grid reveal-stagger">
        {
          poles.map((pole) => (
            <li>
              <a href={pole.href} class="poles__card">
                <span class="poles__numero">{pole.numero}</span>
                <span class="poles__nom">{pole.nom}</span>
                <span class="poles__texte">{pole.texte}</span>
              </a>
            </li>
          ))
        }
      </ul>
    </div>
  </section>

  <!-- Vidéo verticale + méthode -->
  <section class="section">
    <div class="container video-methode">
      <div class="video-frame reveal">
        <video
          controls
          preload="none"
          playsinline
          poster="/videos/mfp-sport-presentation-poster.jpg"
          aria-label="Vidéo de présentation de MFP Sport"
        >
          <source src="/videos/mfp-sport-presentation.mp4" type="video/mp4" />
          Votre navigateur ne peut pas lire cette vidéo.
        </video>
      </div>

      <div class="methode">
        <p class="eyebrow">La méthode</p>
        <h2 class="reveal">De votre premier pas à vos résultats</h2>
        <ol class="methode__list reveal-stagger">
          {
            etapes.map((e, i) => (
              <li class="methode__item">
                <span class="methode__num">{i + 1}</span>
                <div>
                  <h3>{e.titre}</h3>
                  <p>{e.texte}</p>
                </div>
              </li>
            ))
          }
        </ol>
        <Cta />
      </div>
    </div>
  </section>

  {
    actualites.length > 0 && (
      <section class="section actus">
        <div class="container">
          <p class="eyebrow">Actualités</p>
          <h2 class="reveal">La vie du centre</h2>
        </div>
        <div class="actus__scroller" data-actus-scroller>
          {actualites.map((a) => (
            <a class="card actus__card" href={`/actualites/${a.id}/`}>
              {a.data.image && (
                <Image
                  class="actus__img"
                  src={a.data.image}
                  alt={a.data.imageAlt ?? ''}
                  widths={[360, 560]}
                  sizes="340px"
                />
              )}
              <div class="actus__body">
                <p class="actus__date">{a.data.date.toLocaleDateString('fr-FR', { day: 'numeric', month: 'long', year: 'numeric' })}</p>
                <h3>{a.data.titre}</h3>
                <p class="actus__chapo">{a.data.chapo}</p>
                <span class="actus__link">Lire l'article →</span>
              </div>
            </a>
          ))}
        </div>
      </section>
    )
  }

  <section class="cta-final">
    <div class="container">
      <span class="brand-bars"><span></span><span></span><span></span><span></span></span>
      <h2>Prêt·e à faire le point ?</h2>
      <p>Votre premier bilan est offert, sans engagement — le point de départ de votre progression.</p>
      <Cta />
    </div>
  </section>
</Layout>

<script>
  // Défilement automatique doux du bandeau d'actualités (pause au survol,
  // désactivé si prefers-reduced-motion).
  const scroller = document.querySelector('[data-actus-scroller]');
  const reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  if (scroller && !reduced && scroller.scrollWidth > scroller.clientWidth) {
    let paused = false;
    let direction = 1;
    scroller.addEventListener('pointerenter', () => (paused = true));
    scroller.addEventListener('pointerleave', () => (paused = false));
    scroller.addEventListener('focusin', () => (paused = true));
    scroller.addEventListener('focusout', () => (paused = false));
    setInterval(() => {
      if (paused) return;
      const max = scroller.scrollWidth - scroller.clientWidth;
      if (scroller.scrollLeft >= max - 2) direction = -1;
      if (scroller.scrollLeft <= 2) direction = 1;
      scroller.scrollBy({ left: 220 * direction, behavior: 'smooth' });
    }, 3500);
  }
</script>

<style>
  /* HERO SPLIT */
  .hero {
    position: relative;
    background: var(--gradient-brand);
    color: #fff;
    overflow: hidden;
  }

  .hero::after {
    content: '';
    position: absolute;
    inset: 0;
    background: radial-gradient(55% 90% at 78% 20%, rgba(79, 184, 231, 0.28), transparent 65%);
    pointer-events: none;
  }

  .hero__grid {
    position: relative;
    z-index: 1;
    display: grid;
    grid-template-columns: minmax(0, 1.05fr) minmax(0, 0.95fr);
    align-items: center;
    gap: clamp(2rem, 5vw, 4rem);
    padding-block: clamp(3rem, 7vw, 5.5rem);
  }

  .hero h1 {
    color: #fff;
    font-size: clamp(2.3rem, 4.6vw, 3.6rem);
  }

  .hero__lead {
    max-width: 46ch;
    margin: 1.25rem 0 2rem;
    font-size: clamp(1.02rem, 1.6vw, 1.15rem);
    color: #d6e3ef;
  }

  .hero__actions {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
  }

  .hero__visual {
    position: relative;
    min-height: 420px;
  }

  .hero__photo {
    height: auto; /* neutralise l'attribut height intrinsèque de l'image */
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-lg);
    object-fit: cover;
    object-position: center top;
  }

  .hero__photo--main {
    position: absolute;
    right: 0;
    top: 50%;
    transform: translateY(-50%) rotate(2deg);
    width: min(62%, 340px);
    aspect-ratio: 3 / 4;
    z-index: 2;
  }

  .hero__photo--back {
    position: absolute;
    left: 0;
    top: 50%;
    transform: translateY(-58%) rotate(-4deg);
    width: min(48%, 250px);
    aspect-ratio: 3 / 4;
    opacity: 0.9;
  }

  .hero__badge {
    position: absolute;
    z-index: 3;
    bottom: 8%;
    left: 4%;
    display: flex;
    flex-direction: column;
    gap: 0.1rem;
    background: #fff;
    color: var(--color-blue-night);
    border-radius: var(--radius-md);
    padding: 0.8rem 1.1rem;
    box-shadow: var(--shadow-lg);
    font-size: 0.8rem;
    margin: 0;
  }

  .hero__badge-big {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 1.05rem;
    color: var(--color-cta);
  }

  @media (max-width: 900px) {
    .hero__grid {
      grid-template-columns: 1fr;
    }

    .hero__visual {
      min-height: 340px;
    }
  }

  /* Bande photos */
  .salle-mouvement {
    background: var(--color-blue-night);
    padding-block: 1.25rem;
  }

  /* PROFILS */
  .profils__grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(230px, 1fr));
    gap: 1.25rem;
    list-style: none;
    padding: 0;
    margin-top: 2rem;
  }

  .profils__card {
    position: relative;
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
    height: 100%;
    padding: 1.5rem;
    text-decoration: none;
    color: var(--color-ink);
    transition: transform 0.18s ease, box-shadow 0.18s ease;
  }

  .profils__card:hover {
    transform: translateY(-4px);
    box-shadow: var(--shadow-lg);
  }

  .profils__titre {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 1.15rem;
    color: var(--color-blue-night);
  }

  .profils__texte {
    font-size: 0.92rem;
    color: var(--color-slate);
  }

  .profils__arrow {
    margin-top: auto;
    padding-top: 0.75rem;
    color: var(--color-blue-deep);
    font-weight: 700;
  }

  /* POLES */
  .poles {
    background: var(--gradient-brand);
    color: #fff;
  }

  .poles h2 {
    color: #fff;
  }

  .poles__grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(230px, 1fr));
    gap: 1.25rem;
    list-style: none;
    padding: 0;
    margin-top: 2rem;
  }

  .poles__card {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    height: 100%;
    padding: 1.75rem;
    border: 1px solid rgba(255, 255, 255, 0.14);
    border-radius: var(--radius-lg);
    background: rgba(255, 255, 255, 0.04);
    text-decoration: none;
    color: #fff;
    transition: background-color 0.18s ease, transform 0.18s ease;
  }

  .poles__card:hover {
    background: rgba(255, 255, 255, 0.09);
    transform: translateY(-4px);
  }

  .poles__numero {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 1.6rem;
    color: var(--color-blue-light);
  }

  .poles__nom {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 1.3rem;
  }

  .poles__texte {
    font-size: 0.92rem;
    color: #c3d4e4;
  }

  /* VIDEO + METHODE */
  .video-methode {
    display: grid;
    grid-template-columns: minmax(0, 0.8fr) minmax(0, 1.2fr);
    gap: clamp(2rem, 5vw, 4rem);
    align-items: center;
  }

  .video-frame {
    justify-self: center;
    width: min(300px, 80vw);
    border-radius: 2rem;
    padding: 0.6rem;
    background: var(--color-blue-night);
    box-shadow: var(--shadow-lg);
  }

  .video-frame video {
    width: 100%;
    aspect-ratio: 480 / 848;
    border-radius: 1.5rem;
    display: block;
    background: #000;
  }

  .methode__list {
    list-style: none;
    padding: 0;
    margin: 2rem 0;
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  .methode__item {
    display: flex;
    gap: 1rem;
    align-items: flex-start;
  }

  .methode__item h3 {
    margin-bottom: 0.2rem;
  }

  .methode__item p {
    margin: 0;
    color: var(--color-slate);
  }

  .methode__num {
    flex-shrink: 0;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 2.6rem;
    height: 2.6rem;
    border-radius: 999px;
    background: var(--gradient-brand);
    color: #fff;
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 1.15rem;
  }

  @media (max-width: 820px) {
    .video-methode {
      grid-template-columns: 1fr;
    }
  }

  /* ACTUS — bandeau défilant */
  .actus__scroller {
    display: flex;
    gap: 1.25rem;
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    padding: 2rem clamp(1.1rem, 4vw, 3rem);
    max-width: var(--maxw);
    margin-inline: auto;
    scrollbar-width: thin;
  }

  .actus__card {
    flex: 0 0 min(340px, 82vw);
    scroll-snap-align: start;
    text-decoration: none;
    color: var(--color-ink);
    overflow: hidden;
    display: flex;
    flex-direction: column;
    transition: transform 0.18s ease, box-shadow 0.18s ease;
  }

  .actus__card:hover {
    transform: translateY(-4px);
    box-shadow: var(--shadow-lg);
  }

  .actus__img {
    width: 100%;
    height: 190px;
    object-fit: cover;
  }

  .actus__body {
    padding: 1.25rem 1.5rem 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
    flex: 1;
  }

  .actus__date {
    font-size: 0.8rem;
    color: var(--color-slate);
    margin: 0;
  }

  .actus__body h3 {
    font-size: 1.15rem;
    margin: 0;
  }

  .actus__chapo {
    font-size: 0.92rem;
    color: var(--color-slate);
    margin: 0;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .actus__link {
    margin-top: auto;
    padding-top: 0.5rem;
    font-weight: 600;
    color: var(--color-blue-deep);
  }

  /* CTA FINAL */
  .cta-final {
    text-align: center;
    padding-block: clamp(3.5rem, 8vw, 6rem);
  }

  .cta-final .brand-bars {
    margin-bottom: 1.25rem;
  }

  .cta-final h2 {
    margin-bottom: 0.5rem;
  }

  .cta-final p {
    max-width: 46ch;
    margin: 0 auto 2rem;
    color: var(--color-slate);
    font-size: 1.1rem;
  }
</style>
