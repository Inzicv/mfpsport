---
// Accueil — structure définie en docs/etude-refonte.md §G.5.
import Layout from '../layouts/Layout.astro';
import Cta from '../components/Cta.astro';
import { getCollection } from 'astro:content';
import { Image } from 'astro:assets';
import heroImg from '../assets/images/preparation-physique-sprint-arles.jpg';

const actualites = (await getCollection('actualites'))
  .filter((a) => a.data.publie)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 2);

const profils = [
  { titre: 'Je reprends le sport', texte: 'Après une longue pause ou un souci de santé, à votre rythme.', href: '/bilan-gratuit/' },
  { titre: 'Je veux me remettre en forme', texte: 'Perdre du poids, gagner en tonus et en énergie durablement.', href: '/preparation-physique/' },
  { titre: 'Je suis sportif', texte: 'Progresser dans ma discipline et passer un cap.', href: '/preparation-physique/' },
  { titre: 'Je représente une équipe', texte: 'Stages et préparation physique collective pour un club.', href: '/equipes-clubs/' },
];

const poles = [
  { numero: '01', nom: 'Entraînement', href: '/preparation-physique/' },
  { numero: '02', nom: 'Nutrition', href: '/nutrition/' },
  { numero: '03', nom: 'Récupération', href: '/recuperation/' },
  { numero: '04', nom: 'Mental', href: '/preparation-mentale/' },
];

const etapes = [
  { titre: 'Votre bilan offert', texte: 'On évalue votre condition et on définit vos objectifs ensemble.' },
  { titre: 'Un programme personnalisé', texte: 'Adapté à votre niveau, vos objectifs et votre emploi du temps.' },
  { titre: 'Un suivi et des résultats', texte: 'Un accompagnement régulier et des progrès mesurés dans le temps.' },
];
---

<Layout
  title="Salle de sport & coaching personnalisé à Arles"
  description="MFP Sport à Arles : accompagnement sportif premium et humain — entraînement, nutrition, récupération et préparation mentale. Réservez votre bilan gratuit."
>
  <section class="hero">
    <Image
      class="hero__img"
      src={heroImg}
      alt="Séance de préparation physique en sprint résisté à MFP Sport, Arles"
      loading="eager"
      widths={[640, 1024, 1600]}
      sizes="100vw"
    />
    <div class="hero__overlay"></div>
    <div class="hero__content">
      <h1>Votre préparation physique, encadrée par des professionnels — à Arles</h1>
      <p>
        Un accompagnement sportif personnalisé, premium et pluridisciplinaire : entraînement,
        nutrition, récupération et préparation mentale.
      </p>
      <Cta />
    </div>
  </section>

  <section class="profils">
    <h2>Quel que soit votre point de départ</h2>
    <ul class="profils__grid">
      {
        profils.map((p) => (
          <li>
            <a href={p.href}>
              <span class="profils__titre">{p.titre}</span>
              <span class="profils__texte">{p.texte}</span>
            </a>
          </li>
        ))
      }
    </ul>
  </section>

  <section class="poles">
    <h2>4 piliers de la réussite sportive</h2>
    <ul class="poles__grid">
      {
        poles.map((pole) => (
          <li>
            <a href={pole.href}>
              <span class="poles__numero">{pole.numero}</span>
              <span>{pole.nom}</span>
            </a>
          </li>
        ))
      }
    </ul>
  </section>

  <section class="methode">
    <h2>Notre méthode, en trois temps</h2>
    <ol class="methode__grid">
      {
        etapes.map((e, i) => (
          <li>
            <span class="methode__num">{i + 1}</span>
            <h3>{e.titre}</h3>
            <p>{e.texte}</p>
          </li>
        ))
      }
    </ol>
  </section>

  <section class="actualites">
    <h2>Actualités</h2>
    {
      actualites.length === 0 ? (
        <p><em>Aucune actualité publiée pour le moment.</em></p>
      ) : (
        <ul>
          {actualites.map((a) => (
            <li>
              <a href={`/actualites/${a.id}/`}>{a.data.titre}</a>
            </li>
          ))}
        </ul>
      )
    }
  </section>

  <section class="cta-final">
    <h2>Prêt·e à faire le point ?</h2>
    <p>Votre bilan est offert, sans engagement.</p>
    <Cta />
  </section>
</Layout>

<style>
  .hero {
    position: relative;
    color: #fff;
    padding: clamp(3rem, 8vw, 6rem) clamp(1rem, 4vw, 3rem);
    text-align: center;
    isolation: isolate;
    overflow: hidden;
  }

  .hero__img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    z-index: -2;
  }

  .hero__overlay {
    position: absolute;
    inset: 0;
    z-index: -1;
    background: linear-gradient(
      to bottom,
      rgba(11, 39, 64, 0.72),
      rgba(11, 39, 64, 0.82)
    );
  }

  .hero__content {
    max-width: 55rem;
    margin-inline: auto;
  }

  .hero h1 {
    color: #fff;
    max-width: 40ch;
    margin-inline: auto;
  }

  .hero p {
    max-width: 55ch;
    margin: 1rem auto 2rem;
    color: #dbe6f0;
  }

  section {
    padding: clamp(2rem, 6vw, 4rem) clamp(1rem, 4vw, 3rem);
    max-width: 72rem;
    margin-inline: auto;
  }

  .poles__grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: 1.5rem;
    list-style: none;
    padding: 0;
  }

  .poles__grid a {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    padding: 1.5rem;
    background: #fff;
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-card);
    text-decoration: none;
    color: var(--color-blue-night);
    font-family: var(--font-heading);
    font-weight: 600;
  }

  .poles__numero {
    font-size: 2rem;
    color: var(--color-blue-light);
  }

  .profils__grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    gap: 1rem;
    list-style: none;
    padding: 0;
  }

  .profils__grid a {
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
    height: 100%;
    padding: 1.25rem;
    background: #fff;
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-card);
    text-decoration: none;
    color: var(--color-ink);
  }

  .profils__titre {
    font-family: var(--font-heading);
    font-weight: 600;
    color: var(--color-blue-deep);
  }

  .profils__texte {
    font-size: 0.9rem;
    color: var(--color-slate);
  }

  .methode__grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    gap: 1.5rem;
    list-style: none;
    padding: 0;
    counter-reset: none;
  }

  .methode__num {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 2.5rem;
    height: 2.5rem;
    border-radius: 999px;
    background: var(--color-blue-deep);
    color: #fff;
    font-family: var(--font-heading);
    font-weight: 700;
    margin-bottom: 0.5rem;
  }

  .cta-final {
    text-align: center;
    background: #fff;
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-card);
  }
</style>
