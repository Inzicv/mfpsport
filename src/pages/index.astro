---
import Layout from '../layouts/Layout.astro';
import Cta from '../components/Cta.astro';
import SportigoPlanning from '../components/SportigoPlanning.astro';
import { getCollection } from 'astro:content';
import { Image } from 'astro:assets';

import PhotoMarquee from '../components/PhotoMarquee.astro';
import hero from '../assets/images/communaute-adherents-mfp-sport.jpg';
import methode from '../assets/images/coaching-analyse-donnees-vitruve.jpg';
import { localAreaGroups } from '../data/local-seo';

import vieEtirements from '../assets/images/cours-collectif-etirements-sol.jpg';
import vieSouleve from '../assets/images/coaching-souleve-de-terre.jpg';
import viePresso from '../assets/images/pressotherapie-normatec-sourire.jpg';
import vieSteps from '../assets/images/cours-collectif-steps-lumiere.jpg';
import vieBallet from '../assets/images/arles-youth-ballet-company-mfp-sport.jpg';
import vieKettlebell from '../assets/images/kettlebell-swing-fonctionnel.jpg';
import vieComplicite from '../assets/images/complicite-adherents-mfp-sport.jpg';
import vieCircuit from '../assets/images/circuit-training-groupe.jpg';

const vieDuCentre = [
  { src: vieEtirements, alt: 'Cours collectif au sol chez MFP Sport' },
  { src: vieSouleve, alt: 'Séance de coaching individuel, soulevé de terre' },
  { src: viePresso, alt: 'Séance de pressothérapie Normatec' },
  { src: vieSteps, alt: 'Cours collectif sur steps' },
  { src: vieBallet, alt: "L'équipe de l'Arles Youth Ballet Company chez MFP Sport" },
  { src: vieKettlebell, alt: 'Kettlebell swing en zone fonctionnelle' },
  { src: vieComplicite, alt: 'Deux adhérents de MFP Sport' },
  { src: vieCircuit, alt: 'Circuit training en groupe' },
];

const actualites = (await getCollection('actualites'))
  .filter((a) => a.data.publie)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 2);

const pros = (await getCollection('professionnels'))
  .filter((p) => p.data.actif && p.data.photo)
  .sort((a, b) => a.data.ordre - b.data.ordre);

const poles = [
  {
    numero: '01',
    nom: 'Entraînement',
    texte: 'Préparation physique, coaching individuel et équipements de haute performance.',
    href: '/preparation-physique/',
  },
  {
    numero: '02',
    nom: 'Nutrition',
    texte: 'Un suivi alimentaire construit autour de votre santé, de votre rythme et de vos objectifs.',
    href: '/nutrition/',
  },
  {
    numero: '03',
    nom: 'Récupération',
    texte: 'Ostéopathie, massages, pressothérapie et protocoles chaud-froid réunis au même endroit.',
    href: '/recuperation/',
  },
  {
    numero: '04',
    nom: 'Mental',
    texte: 'Gestion du stress, concentration et préparation à la compétition ou aux défis du quotidien.',
    href: '/preparation-mentale/',
  },
];

const etapes = [
  ['Évaluer', 'Un premier bilan pour comprendre votre point de départ, vos contraintes et vos objectifs.'],
  ['Construire', 'Un parcours sur mesure qui coordonne les expertises dont vous avez réellement besoin.'],
  ['Mesurer', 'Un suivi régulier, des repères concrets et un programme qui évolue avec vous.'],
];
---

<Layout
  title="Salle de sport et coach sportif à Arles"
  description="MFP Sport, salle de sport à Arles : coaching sportif personnalisé, préparation physique, cours, nutrition et récupération pour Arles, la Camargue et les Alpilles."
>
  <section class="hero">
    <Image
      class="hero__image"
      src={hero}
      alt="Les adhérents de MFP Sport réunis devant la fresque du centre, à Arles"
      loading="eager"
      widths={[768, 1280, 1920]}
      sizes="100vw"
    />
    <div class="hero__veil"></div>
    <div class="container hero__content">
      <p class="eyebrow eyebrow--light">Salle de sport · Coach sportif · Arles</p>
      <h1>Votre espace sportif pour un accompagnement sur mesure</h1>
      <p class="hero__lead">
        Entraînement, nutrition, récupération et préparation mentale : une équipe de
        professionnels construit avec vous un parcours adapté à vos objectifs et à votre quotidien.
      </p>
      <div class="hero__actions">
        <Cta />
        <a class="btn-ghost" href="/planning/">Voir le planning</a>
      </div>
    </div>
    <a class="hero__scroll" href="#approche">Découvrir notre approche <span aria-hidden="true">↓</span></a>
  </section>

  {actualites.length > 0 && (
    <aside class="news-ticker" aria-label="Dernières actualités">
      <a class="news-ticker__label" href="/actualites/">En ce moment</a>
      <div class="news-ticker__viewport">
        {[0, 1].map((copy) => (
          <div class="news-ticker__track" aria-hidden={copy === 1 ? 'true' : undefined}>
            {actualites.map((actu) => (
              <a href={`/actualites/${actu.id}/`} tabindex={copy === 1 ? '-1' : undefined}>
                <time>{actu.data.date.toLocaleDateString('fr-FR', { day: '2-digit', month: 'short' })}</time>
                <strong>{actu.data.titre}</strong>
                <span aria-hidden="true">→</span>
              </a>
            ))}
          </div>
        ))}
      </div>
    </aside>
  )}

  <section class="trust" aria-label="MFP Sport en quelques repères">
    <div class="container trust__grid">
      <p><strong>300 m²</strong><span>dédiés à votre progression</span></p>
      <p><strong>4 expertises</strong><span>coordonnées dans un même lieu</span></p>
      <p><strong>6 jours sur 7</strong><span>pour avancer à votre rythme</span></p>
      <p><strong>À Arles</strong><span>au cœur de votre territoire</span></p>
    </div>
  </section>

  <section class="section manifesto" id="approche">
    <div class="container manifesto__grid">
      <div>
        <p class="eyebrow">La performance accompagnée</p>
        <h2>Bien plus qu’une salle de sport</h2>
      </div>
      <div class="manifesto__copy">
        <p>
          Ici, vous n’êtes pas laissé·e seul·e face aux machines. Nous partons de votre réalité
          pour mobiliser les bonnes compétences, au bon moment.
        </p>
        <p>
          Reprise d’activité, remise en forme, préparation d’une compétition ou suivi collectif :
          votre parcours reste lisible, humain et mesurable.
        </p>
        <a href="/le-centre/">Découvrir le centre →</a>
      </div>
    </div>
  </section>

  <section class="expertises">
    <div class="container">
      <div class="section-head">
        <div>
          <p class="eyebrow eyebrow--light">Un parcours complet</p>
          <h2>Quatre expertises.<br />Une seule progression.</h2>
        </div>
        <p>Chaque pôle peut intervenir seul ou s’intégrer dans un accompagnement coordonné.</p>
      </div>
      <ol class="expertises__list">
        {poles.map((pole) => (
          <li>
            <a href={pole.href}>
              <span class="expertises__num">{pole.numero}</span>
              <span class="expertises__name">{pole.nom}</span>
              <span class="expertises__text">{pole.texte}</span>
              <span class="expertises__arrow" aria-hidden="true">↗</span>
            </a>
          </li>
        ))}
      </ol>
    </div>
  </section>

  <section class="section methode">
    <div class="container methode__grid">
      <div class="methode__visual">
        <Image
          src={methode}
          alt="Évaluation de la force avec un capteur Kinvent chez MFP Sport"
          widths={[480, 768]}
          sizes="(max-width: 800px) 100vw, 46vw"
        />
        <p><strong>Votre bilan est offert.</strong><br />Le point de départ, jamais une formalité.</p>
      </div>
      <div>
        <p class="eyebrow">Notre méthode</p>
        <h2>Comprendre avant de programmer</h2>
        <ol class="methode__steps">
          {etapes.map(([titre, texte], index) => (
            <li>
              <span>0{index + 1}</span>
              <div><h3>{titre}</h3><p>{texte}</p></div>
            </li>
          ))}
        </ol>
        <Cta />
      </div>
    </div>
  </section>

  <section class="section planning-home">
    <div class="container">
      <SportigoPlanning compact />
    </div>
  </section>

  {pros.length > 0 && (
    <section class="section equipe-home">
      <div class="container">
        <div class="section-head section-head--dark">
          <div><p class="eyebrow eyebrow--light">Vos professionnels</p><h2>Une équipe autour de vous</h2></div>
          <a href="/equipe/">Rencontrer toute l’équipe →</a>
        </div>
        <ul class="equipe-home__grid">
          {pros.map((pro) => (
            <li>
              <a href="/equipe/">
                <span class="equipe-home__photo">
                  <Image src={pro.data.photo!} alt={`${pro.data.nom}, ${pro.data.role}`} widths={[320, 520]} sizes="(max-width: 560px) 100vw, (max-width: 860px) 50vw, 20vw" />
                </span>
                <span><strong>{pro.data.nom}</strong><small>{pro.data.role}</small></span>
              </a>
            </li>
          ))}
        </ul>
      </div>
    </section>
  )}

  <section class="section vie-du-centre">
    <div class="container">
      <div class="section-head section-head--light">
        <div><p class="eyebrow">La vie du centre</p><h2>Des séances, des progrès, une équipe</h2></div>
      </div>
    </div>
    <PhotoMarquee images={vieDuCentre} />
  </section>

  <section class="section local-home" aria-labelledby="local-title">
    <div class="container local-home__grid">
      <div>
        <p class="eyebrow">Votre centre sportif local</p>
        <h2 id="local-title">À Arles, au service de la Camargue et des Alpilles</h2>
        <p>
          Installé au 15 Chemin des Moines à Arles, MFP Sport accueille les sportifs de tous
          niveaux pour des séances encadrées, un programme personnalisé ou une préparation
          physique complète.
        </p>
        <a href="/salle-de-sport-arles/">Découvrir le centre et notre zone d’accueil →</a>
      </div>
      <div class="local-home__areas">
        {localAreaGroups.map((group) => (
          <div>
            <h3>{group.name}</h3>
            <p>{group.places.join(' · ')}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="final-cta">
    <div class="container final-cta__inner">
      <div><p class="eyebrow eyebrow--light">Votre point de départ</p><h2>Parlons de ce que vous voulez accomplir.</h2></div>
      <div><Cta /><p>Premier bilan offert · Sans engagement</p></div>
    </div>
  </section>
</Layout>

<style>
  .hero { position: relative; min-height: min(820px, calc(100svh - 84px)); display: flex; align-items: flex-end; overflow: hidden; background: var(--color-blue-night); color: #fff; }
  .hero__image { position: absolute; inset: 0; width: 100%; height: 100%; object-fit: cover; object-position: center 28%; }
  .hero__veil { position: absolute; inset: 0; background: linear-gradient(90deg, rgba(5,21,33,.96) 0%, rgba(5,21,33,.8) 42%, rgba(5,21,33,.18) 76%), linear-gradient(0deg, rgba(5,21,33,.72), transparent 45%); }
  .hero__content { position: relative; z-index: 1; width: 100%; padding-block: clamp(5rem, 11vw, 9rem); }
  .hero h1 { max-width: 13ch; color: #fff; font-size: clamp(3rem, 6.5vw, 6.25rem); letter-spacing: -.045em; }
  .hero__lead { max-width: 59ch; font-size: clamp(1.05rem, 1.5vw, 1.25rem); color: #d7e3ea; margin: 1.5rem 0 2rem; }
  .hero__actions { display: flex; flex-wrap: wrap; gap: .8rem; }
  .hero__scroll { position: absolute; z-index: 2; right: clamp(1.1rem, 4vw, 3rem); bottom: 2rem; color: #fff; text-decoration: none; font-size: .85rem; letter-spacing: .04em; }
  .hero__scroll span { margin-left: .5rem; color: var(--color-blue-light); }

  .news-ticker { display: flex; min-height: 4.25rem; color: #fff; background: var(--color-blue-deep); border-bottom: 1px solid rgba(255,255,255,.18); overflow: hidden; }
  .news-ticker__label { position: relative; z-index: 2; display: flex; flex: 0 0 auto; align-items: center; padding-inline: max(1.1rem, calc((100vw - var(--maxw)) / 2 + 3rem)); padding-right: 2rem; color: #fff; background: var(--color-blue-night); font-family: var(--font-display); font-size: .75rem; font-weight: 700; letter-spacing: .13em; text-decoration: none; text-transform: uppercase; }
  .news-ticker__viewport { display: flex; min-width: 0; overflow: hidden; }
  .news-ticker__track { display: flex; flex: none; align-items: stretch; min-width: 100%; animation: news-scroll 28s linear infinite; }
  .news-ticker:hover .news-ticker__track, .news-ticker:focus-within .news-ticker__track { animation-play-state: paused; }
  .news-ticker__track a { display: flex; flex: 0 0 auto; align-items: center; gap: 1rem; min-width: 31rem; padding: .85rem 2.25rem; border-right: 1px solid rgba(255,255,255,.2); color: #fff; text-decoration: none; }
  .news-ticker__track time { color: #a9d9f2; font-size: .72rem; letter-spacing: .08em; text-transform: uppercase; }
  .news-ticker__track strong { font-size: .9rem; white-space: nowrap; }
  .news-ticker__track span { color: var(--color-blue-light); font-size: 1.2rem; }
  @keyframes news-scroll { to { transform: translateX(-100%); } }

  .trust { background: #fff; border-bottom: 1px solid var(--color-line); }
  .trust__grid { display: grid; grid-template-columns: repeat(4, 1fr); padding-block: 1.6rem; }
  .trust p { display: flex; flex-direction: column; gap: .15rem; margin: 0; padding: .25rem 1.5rem; border-left: 1px solid var(--color-line); }
  .trust p:first-child { padding-left: 0; border-left: 0; }
  .trust strong { color: var(--color-blue-night); font-family: var(--font-display); font-size: 1.2rem; }
  .trust span { color: var(--color-slate); font-size: .78rem; }

  .manifesto__grid { display: grid; grid-template-columns: .85fr 1.15fr; gap: clamp(3rem, 8vw, 8rem); align-items: start; }
  .manifesto h2 { font-size: clamp(2.6rem, 5vw, 4.7rem); }
  .manifesto__copy { max-width: 41rem; padding-top: 2rem; }
  .manifesto__copy p:first-child { color: var(--color-blue-night); font-size: clamp(1.25rem, 2.1vw, 1.65rem); line-height: 1.45; }
  .manifesto__copy a { display: inline-block; margin-top: 1rem; font-weight: 700; text-decoration: none; }

  .expertises { color: #fff; background: var(--color-blue-night); padding-block: clamp(4.5rem, 9vw, 8rem); }
  .section-head { display: flex; justify-content: space-between; gap: 3rem; align-items: end; margin-bottom: clamp(2.5rem, 5vw, 4.5rem); }
  .section-head h2 { color: #fff; margin: 0; }
  .section-head > p { max-width: 34ch; color: #aac0cf; }
  .expertises__list { list-style: none; padding: 0; margin: 0; border-top: 1px solid rgba(255,255,255,.18); }
  .expertises__list li { border-bottom: 1px solid rgba(255,255,255,.18); }
  .expertises__list a { display: grid; grid-template-columns: 5rem minmax(11rem,.7fr) 1fr 2rem; gap: 1rem; align-items: center; padding: clamp(1.4rem, 3vw, 2.2rem) .5rem; color: #fff; text-decoration: none; transition: background-color .2s, padding .2s; }
  .expertises__list a:hover { padding-inline: 1.25rem; background: rgba(255,255,255,.055); }
  .expertises__num { color: var(--color-blue-light); font-family: var(--font-display); }
  .expertises__name { font-family: var(--font-display); font-size: clamp(1.5rem, 3vw, 2.4rem); font-weight: 700; }
  .expertises__text { color: #b9cad5; font-size: .95rem; }
  .expertises__arrow { font-size: 1.5rem; color: var(--color-blue-light); }

  .methode__grid { display: grid; grid-template-columns: .9fr 1.1fr; gap: clamp(3rem, 7vw, 7rem); align-items: center; }
  .methode__visual { position: relative; }
  .methode__visual img { width: 100%; max-height: 680px; object-fit: cover; }
  .methode__visual > p { position: absolute; left: 0; bottom: 0; margin: 0; padding: 1.1rem 1.35rem; color: #fff; background: var(--color-blue-deep); font-size: .9rem; }
  .methode__steps { list-style: none; padding: 0; margin: 2.5rem 0; border-top: 1px solid var(--color-line); }
  .methode__steps li { display: grid; grid-template-columns: 3rem 1fr; gap: 1rem; padding: 1.3rem 0; border-bottom: 1px solid var(--color-line); }
  .methode__steps > li > span { color: var(--color-blue-deep); font-family: var(--font-display); font-weight: 700; }
  .methode__steps h3, .methode__steps p { margin: 0; }
  .methode__steps p { color: var(--color-slate); font-size: .95rem; }

  .planning-home { background: #e8edef; }

  .equipe-home { color: #fff; background: #0c2638; }
  .section-head--dark > a { color: #fff; text-decoration: none; }
  .equipe-home__grid { display: grid; grid-template-columns: repeat(5, minmax(0, 1fr)); list-style: none; gap: 1px; padding: 0; margin: 0; background: rgba(255,255,255,.16); }
  .equipe-home__grid li { background: #0c2638; }
  .equipe-home__grid a { display: flex; flex-direction: column; height: 100%; color: #fff; text-decoration: none; }
  .equipe-home__photo { display: block; width: 100%; aspect-ratio: 4/5; min-height: 0; padding: 0; overflow: hidden; background: #132f42; }
  .equipe-home__photo :global(img) { width: 100%; height: 100%; object-fit: cover; object-position: center top; filter: saturate(.72); transition: filter .25s; }
  .equipe-home__grid a:hover .equipe-home__photo :global(img) { filter: saturate(1); }
  .equipe-home__grid a > span:last-child { display: flex; flex: 1; flex-direction: column; min-height: 7rem; padding: 1rem; }
  .equipe-home__grid strong { font-family: var(--font-display); font-size: 1.05rem; }
  .equipe-home__grid small { margin-top: .3rem; color: #a9bfcd; line-height: 1.4; }

  .section-head--light h2 { color: var(--color-blue-night); }
  .section-head--light a { font-weight: 700; text-decoration: none; }
  .vie-du-centre { background: #fff; padding-bottom: clamp(3rem, 7vw, 5rem); }
  .vie-du-centre .section-head { margin-bottom: 1.75rem; }

  .local-home { background: #e8edef; }
  .local-home__grid { display: grid; grid-template-columns: .9fr 1.1fr; gap: clamp(3rem, 7vw, 7rem); align-items: start; }
  .local-home__grid > div:first-child > p:not(.eyebrow) { max-width: 54ch; }
  .local-home__grid > div:first-child > a { display: inline-block; margin-top: 1rem; font-weight: 700; text-decoration: none; }
  .local-home__areas { border-top: 1px solid var(--color-line); }
  .local-home__areas > div { padding: 1.25rem 0; border-bottom: 1px solid var(--color-line); }
  .local-home__areas h3, .local-home__areas p { margin: 0; }
  .local-home__areas h3 { margin-bottom: .35rem; font-size: 1.05rem; }
  .local-home__areas p { color: var(--color-slate); font-size: .9rem; }

  .actus__grid { display: grid; grid-template-columns: .55fr 1.45fr; gap: clamp(2rem, 7vw, 7rem); }
  .actus__grid > div a { font-weight: 700; text-decoration: none; }
  .actus ul { list-style: none; padding: 0; margin: 0; border-top: 1px solid var(--color-line); }
  .actus li { border-bottom: 1px solid var(--color-line); }
  .actus li a { display: grid; grid-template-columns: 9rem 1fr auto; gap: 1rem; padding: 1.4rem 0; color: var(--color-blue-night); text-decoration: none; align-items: center; }
  .actus time { color: var(--color-slate); font-size: .8rem; }

  .final-cta { color: #fff; background: var(--color-blue-deep); padding-block: clamp(3.5rem, 7vw, 6rem); }
  .final-cta__inner { display: flex; justify-content: space-between; align-items: end; gap: 3rem; }
  .final-cta h2 { max-width: 16ch; color: #fff; }
  .final-cta__inner > div:last-child { text-align: right; }
  .final-cta__inner > div:last-child p { font-size: .8rem; color: #c3d9e7; }
  .final-cta :global(.cta) { background: #fff; color: var(--color-blue-night); }

  @media (max-width: 860px) {
    .hero { min-height: 720px; }
    .hero__veil { background: linear-gradient(90deg, rgba(5,21,33,.94), rgba(5,21,33,.55)), linear-gradient(0deg, rgba(5,21,33,.8), transparent); }
    .hero__scroll { display: none; }
    .trust__grid { grid-template-columns: repeat(2, 1fr); }
    .trust p:nth-child(3) { border-left: 0; padding-left: 0; }
    .manifesto__grid, .methode__grid, .local-home__grid { grid-template-columns: 1fr; }
    .expertises__list a { grid-template-columns: 3rem 1fr 2rem; }
    .expertises__text { grid-column: 2 / 3; }
    .expertises__arrow { grid-column: 3; grid-row: 1; }
    .equipe-home__grid { grid-template-columns: repeat(2, 1fr); }
    .equipe-home__grid li:last-child { grid-column: 1 / -1; max-width: 50%; width: 100%; justify-self: center; }
  }

  @media (max-width: 560px) {
    .hero h1 { font-size: clamp(2.75rem, 13vw, 4rem); }
    .trust__grid { grid-template-columns: 1fr 1fr; }
    .trust p { padding: .75rem; }
    .section-head, .final-cta__inner { align-items: flex-start; flex-direction: column; }
    .equipe-home__grid { grid-template-columns: 1fr; }
    .equipe-home__grid li:last-child { grid-column: auto; max-width: none; }
    .news-ticker { min-height: 3.8rem; }
    .news-ticker__label { padding-inline: 1rem; font-size: .65rem; }
    .news-ticker__track a { min-width: 22rem; padding-inline: 1.25rem; }
    .news-ticker__track strong { max-width: 16rem; overflow: hidden; text-overflow: ellipsis; }
    .final-cta__inner > div:last-child { text-align: left; }
  }

  @media (prefers-reduced-motion: reduce) {
    .news-ticker__viewport { overflow-x: auto; }
    .news-ticker__track { animation: none; }
    .news-ticker__track[aria-hidden='true'] { display: none; }
  }
</style>
